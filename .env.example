# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Model id（不要加 models/ 前缀）。常用：gemini-2.5-flash、gemini-3-flash-preview、gemini-3.1-pro-preview
# 注意：没有 gemini-3.1-flash-preview 这个 id；若要 3.1 轻量版请用 gemini-3.1-flash-lite-preview
GEMINI_MODEL=gemini-3-flash-preview
# 用于音频逐字字幕的 Gemini 模型（需支持音频输入）
GEMINI_SUBTITLE_MODEL=gemini-3-flash-preview
# 长音频按多少秒切片后分多次调用 Gemini（避免单次输出撞 max_output_tokens 被截断）
# SUBTITLE_CHUNK_SEC=300
# 503/过载时可选降级模型（留空则只重试主模型）
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash
# 重试次数与退避秒数（指数退避，单次最多等待约 120s）
# GEMINI_MAX_RETRIES=6
# GEMINI_RETRY_BASE_SEC=2
# Number of conversation rounds (optional, random 20-50 if unset)
# ROUND_CN=30

# Cloudflare D1 database
PODCAST_D1_DB_ID=your_d1_database_id
# https://dash.cloudflare.com/a43480697991446ac2db1453a1d54ce1/api-tokens
CLOUDFLARE_API_KEY=your_cloudflare_api_key

# Cloudflare R2 storage
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
# https://dash.cloudflare.com/a43480697991446ac2db1453a1d54ce1/r2/api-tokens
CLOUDFLARE_ACCESS_KEY=your_r2_access_key
CLOUDFLARE_SECRET_KEY=your_r2_secret_key
CLOUDFLARE_REGION=apac

# S3/R2 public base URL for uploaded files
S3_BUCKET_URL=https://your-bucket-url.example.com

# SiliconFlow API for AI cover image generation
# https://cloud.siliconflow.cn/me/account/ak
SILICONCLOUD_API_KEY=your_siliconflow_api_key
